{
	"name": "voicebox-cli",
	"version": "0.1.2",
	"description": "Command-line client for the voicebox TTS API",
	"type": "module",
	"license": "MIT",
	"author": "Jerome Etienne",
	"keywords": [
		"voicebox",
		"tts",
		"text-to-speech",
		"cli",
		"voice"
	],
	"bin": {
		"voicebox-cli": "dist/cli.js"
	},
	"main": "dist/misc/voicebox_client.js",
	"types": "dist/misc/voicebox_client.d.ts",
	"exports": {
		".": {
			"types": "./dist/misc/voicebox_client.d.ts",
			"import": "./dist/misc/voicebox_client.js"
		}
	},
	"files": [
		"dist",
		"dotclaude_folder"
	],
	"engines": {
		"node": ">=20"
	},
	"scripts": {
		"cli": "tsx src/cli.ts",
		"symlink:dotclaude": "bash scripts/symlink_dotclaude.sh",
		"clean:outputs": "find outputs -type f ! -name .gitignore -delete",
		"test": "tsx --test test/*.test.ts",
		"typecheck": "tsc -p tsconfig.json",
		"build": "tsc -p tsconfig.build.json",
		"prepublishOnly": "npm run typecheck && npm test && npm run build",
		"publish:all": "npm run build && npm version patch && npm publish"
	},
	"dependencies": {
		"commander": "^15.0.0",
		"ffmpeg-static": "^5.3.0"
	},
	"devDependencies": {
		"@types/node": "^26.1.0",
		"tsx": "^4.19.2",
		"typescript": "^5.7.2"
	},
	"publishConfig": {
		"access": "public"
	}
}
